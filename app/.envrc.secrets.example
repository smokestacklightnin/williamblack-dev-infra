# Cloudflare credentials. Copy to `.envrc.secrets` (gitignored) and fill in.
# Loaded by .envrc via `source_env_if_exists`.

# Account ID — visible in the Cloudflare dashboard right sidebar.
export TF_VAR_cloudflare_account_id=your-cloudflare-account-id

# API token — create at https://dash.cloudflare.com/profile/api-tokens
# Required permissions:
#   Zone:Edit, DNS:Edit, Workers Scripts:Edit, Workers Routes:Edit
# Scope to a single zone (your domain) once it's been added to Cloudflare.
export TF_VAR_cloudflare_api_token=your-cloudflare-api-token
